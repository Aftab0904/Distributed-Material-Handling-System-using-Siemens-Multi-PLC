FUNCTION_BLOCK "FB_Motor_Control"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      i_Start : Bool;   // Start Command (Pushbutton or Logic)
      i_Stop : Bool;    // Stop Command (NC)
      i_Interlock : Bool;   // Safety/Process Interlock (1=OK)
      i_Fault_Reset : Bool;   // Fault Reset
      i_Feedback : Bool;   // Aux Contact Feedback (1=Running)
   END_VAR

   VAR_OUTPUT 
      q_Run : Bool;   // Motor Run Command
      q_Fault : Bool;   // Motor Fault (Feedback Mismatch)
   END_VAR

   VAR 
      s_Run_Latch : Bool;
      s_Timer_Feedback {InstructionName := 'TON_TIME'; LibVersion := '1.0'} : TON_TIME;
   END_VAR


BEGIN
	// Motor Control Logic with Interlocks
	IF #i_Stop OR NOT #i_Interlock THEN
	    #s_Run_Latch := FALSE;
	ELSIF #i_Start THEN
	    #s_Run_Latch := TRUE;
	END_IF;
	
	#q_Run := #s_Run_Latch;
	
	// Feedback Monitoring (Fault Detection)
	#s_Timer_Feedback(IN := #q_Run AND NOT #i_Feedback,
	                  PT := T#2S);
	
	IF #s_Timer_Feedback.Q THEN
	    #q_Fault := TRUE;
	END_IF;
	
	IF #i_Fault_Reset THEN
	    #q_Fault := FALSE;
	END_IF;
	
END_FUNCTION_BLOCK
